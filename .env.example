# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_NAME=madeinweb-teste
APP_VERSION=0.1.0
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── LLM (OpenAI | Groq) ──────────────────────────────────────────────────────
LLM_PROVIDER=groq            # openai | groq

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024

# Groq
GROQ_API_KEY=gsk-...
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1024

# ── RAG / FAISS ───────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=local        # local (fastembed, gratuito) | openai (exige créditos)
VECTORSTORE_PATH=artifacts/vectorstore
KNOWLEDGE_BASE_PATH=data/knowledge_base
RAG_TOP_K=4                  # Quantos trechos recuperar por consulta

# ── Build Docker / Railway (treino na imagem) ─────────────────────────────────
# Opcional: força uma URL; senão o script tenta mirrors (GitHub raw) e falha só se todos caírem.
# KC_HOUSE_DATA_URL=https://...

# ── Artefatos de ML ───────────────────────────────────────────────────────────
MODEL_PATH=artifacts/model/house_price_model.joblib
PREPROCESSOR_PATH=artifacts/model/preprocessor.joblib
METADATA_PATH=artifacts/model/metadata.json

# ── Banco de dados (opcional) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/house_price_db

# ── Streamlit / CORS (API) ────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8001
# Em APP_ENV=production: origens do React (browser), separadas por vírgula.
# CORS_ORIGINS=https://meu-front.vercel.app,http://localhost:5173
